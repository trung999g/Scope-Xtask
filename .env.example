# Tuỳ chọn: backend nội bộ
# VITE_API_BASE_URL=https://api.example.com

# OpenAI — Chấm điểm chỉ dùng ChatGPT API (api.openai.com), model mặc định gpt-4o
# VITE_OPENAI_API_KEY=sk-...
# Hoặc key chung (OpenAI sk-…):
# VITE_AI_API_KEY=sk-...
# Model OpenAI (vd. gpt-4o-mini). Không còn hỗ trợ Gemini trong app.
# VITE_AI_MODEL=gpt-4o
# Nghỉ giữa mọi request (ms) — mặc định code ~9000
# VITE_AI_GLOBAL_GAP_MS=12000
# VITE_AI_CHUNK_GAP_MS=12000
# Chấm AI ngay sau khi tải sheet — mặc định TẮT; bật: true hoặc 1
# VITE_AI_AUTO_SCORE=true
# Tối đa phiếu / mỗi lô chấm (mặc định 14)
# VITE_AI_SCORE_CHUNK_SIZE=14
# Giới hạn độ dài JSON payload mỗi lô (ký tự, mặc định 22000)
# VITE_AI_SCORE_MAX_PAYLOAD_CHARS=22000
# Nghỉ giữa các lô chấm (ms)
# VITE_AI_SCORE_GAP_MS=12000
