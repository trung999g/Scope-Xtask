# API endpoint AI cấu hình tại tab Prompt AI (input runtime), không đọc từ env.
# Key mặc định khi deploy (ô key trên tab Prompt để trống thì dùng các biến này):
# VITE_OPENAI_API_KEY=sk-...
# Hoặc key chung (Bearer như OpenAI):
# VITE_AI_API_KEY=sk-...
# Nhập key tại tab Prompt sẽ ghi đè (ưu tiên hơn env).
# Model: gpt-4o (cloud) hoặc id nội bộ (vd. MWG khi dùng base URL tùy chỉnh)
# VITE_AI_MODEL=gpt-4o
# VITE_AI_MODEL=MWG
# System prompt ngắn hơn (~ít token) khi hay bị 429 — thử kết hợp với model mini
# VITE_AI_COMPACT_SYSTEM_PROMPT=true
# Nghỉ giữa mọi request OpenAI (ms) — mặc định 14000; tăng lên 20000–30000 nếu 429
# VITE_AI_GLOBAL_GAP_MS=20000
# VITE_AI_CHUNK_GAP_MS=12000
# Chấm AI ngay sau khi tải sheet — mặc định TẮT; bật: true hoặc 1
# VITE_AI_AUTO_SCORE=true
# Tối đa phiếu / mỗi lô chấm (mặc định 10; giảm nếu timeout)
# VITE_AI_SCORE_CHUNK_SIZE=10
# Giới hạn độ dài JSON payload mỗi lô (ký tự, mặc định 22000)
# VITE_AI_SCORE_MAX_PAYLOAD_CHARS=22000
# Nghỉ giữa các lô chấm (ms)
# VITE_AI_SCORE_GAP_MS=12000
