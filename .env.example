# Tuỳ chọn: backend nội bộ
# VITE_API_BASE_URL=https://api.example.com

# Google AI Studio (Gemini) — chỉ commit .env.example; tạo file .env cục bộ hoặc
# trên Vercel: Project → Settings → Environment Variables → VITE_GEMINI_API_KEY (Production/Preview).
# VITE_GEMINI_API_KEY=
# Model chính: gemini-2.5-flash-lite (multimodal, phân loại/tài liệu, throughput tốt trên free tier)
# VITE_AI_MODEL=gemini-2.5-flash-lite
# Dự phòng khi 429/503 (mặc định trong code: gemini-2.5-flash nếu không khai báo)
# VITE_AI_FALLBACK_MODEL=gemini-2.5-flash
# Nghỉ giữa mọi request (ms) — mặc định code 9000; free tier: thử 10000–15000 nếu vẫn 429
# VITE_AI_GLOBAL_GAP_MS=12000
# VITE_AI_CHUNK_GAP_MS=12000
# Chấm AI ngay sau khi tải sheet (mặc định TẮT nếu không gán). Bật: true hoặc 1
# VITE_AI_AUTO_SCORE=true
